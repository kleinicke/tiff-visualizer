{
  "name": "tiff-visualizer",
  "displayName": "Scientific Image Visualizer",
  "description": "Analyze more than 25 integer and floating-point image formats with precise pixel inspection, multidimensional navigation, interactive visualization, comparison, and layer compositing.",
  "version": "1.8.1",
  "publisher": "kleinicke",
  "icon": "icon.png",
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "browser": "./out/extension.web.js",
  "categories": [
    "Data Science",
    "Visualization",
    "Other"
  ],
  "qna": "https://github.com/kleinicke/tiff-visualizer/issues",
  "galleryBanner": {
    "color": "#1e2e1e",
    "theme": "dark"
  },
  "keywords": [
    "tiff",
    "tif",
    "exr",
    "openexr",
    "ppm",
    "pgm",
    "pbm",
    "pfm",
    "image",
    "viewer",
    "visualizer",
    "wasm",
    "float",
    "scientific",
    "raster",
    "depth",
    "analysis",
    "pixel",
    "gamma",
    "uint16",
    "float16",
    "hdr",
    "jxl",
    "jpeg xl",
    "nan",
    "mask",
    "preview",
    "netpbm",
    "png",
    "jpg",
    "jpeg",
    "npy",
    "ome-tiff",
    "multi-page",
    "fits",
    "dicom",
    "medical imaging",
    "netcdf",
    "openraster",
    "ora",
    "kra",
    "krita",
    "psd",
    "photoshop",
    "psb",
    "xcf",
    "gimp",
    "affinity photo",
    "afphoto",
    "layered image",
    "layers"
  ],
  "extensionKind": [
    "ui",
    "workspace"
  ],
  "capabilities": {
    "virtualWorkspaces": true,
    "untrustedWorkspaces": {
      "supported": true
    }
  },
  "contributes": {
    "customEditors": [
      {
        "viewType": "tiffVisualizer.previewEditor",
        "displayName": "Scientific Image Visualizer",
        "priority": "default",
        "selector": [
          {
            "filenamePattern": "*.{tif,tiff,tf2,tf8,btf,exr,pfm,npy,npz,ppm,pgm,pbm,hdr,tga,jxl,fits,fit,fts,dcm,dicom,DCM,DICOM,nc,cdf,ora,kra,psd,psb,xcf,afphoto,af}"
          }
        ]
      },
      {
        "viewType": "tiffVisualizer.previewEditor.option",
        "displayName": "Scientific Image Visualizer",
        "priority": "option",
        "selector": [
          {
            "filenamePattern": "*.{png,jpeg,jpg,bmp,ico,webp,avif}"
          }
        ]
      }
    ],
    "commands": [
	  {
		"command": "tiffVisualizer.openDicomFolder",
		"title": "Open Folder as DICOM Dataset",
		"category": "TIFF Visualizer"
	  },
      {
        "command": "tiffVisualizer.zoomIn",
        "title": "Zoom In",
        "category": "TIFF Visualizer"
      },
      {
        "command": "tiffVisualizer.zoomOut",
        "title": "Zoom Out",
        "category": "TIFF Visualizer"
      },
      {
        "command": "tiffVisualizer.copyImage",
        "title": "Copy Image",
        "category": "TIFF Visualizer"
      },
      {
        "command": "tiffVisualizer.pastePosition",
        "title": "Paste Position",
        "category": "TIFF Visualizer"
      },
      {
        "command": "tiffVisualizer.resetZoom",
        "title": "Reset Zoom",
        "category": "TIFF Visualizer"
      },
      {
        "command": "tiffVisualizer.setNormalizationRange",
        "title": "Set Normalization Range",
        "category": "TIFF Visualizer"
      },
      {
        "command": "tiffVisualizer.exportLayers",
        "title": "Export…",
        "category": "TIFF Visualizer"
      },
      {
        "command": "tiffVisualizer.setGamma",
        "title": "Set Gamma",
        "category": "TIFF Visualizer"
      },
      {
        "command": "tiffVisualizer.setBrightness",
        "title": "Set Brightness",
        "category": "TIFF Visualizer"
      },
      {
        "command": "tiffVisualizer.selectForCompare",
        "title": "Select for Compare",
        "category": "TIFF Visualizer"
      },
      {
        "command": "tiffVisualizer.compareWithSelected",
        "title": "Compare with Selected",
        "category": "TIFF Visualizer"
      },
      {
        "command": "tiffVisualizer.toggleLayers",
        "title": "Open Layers View",
        "category": "TIFF Visualizer"
      },
      {
        "command": "tiffVisualizer.addLayer",
        "title": "Add Image as Layer",
        "category": "TIFF Visualizer"
      },
      {
        "command": "tiffVisualizer.toggleNanColor",
        "title": "Toggle NaN Color (Black/Fuchsia)",
        "category": "TIFF Visualizer"
      },
      {
        "command": "tiffVisualizer.browseAndAddToCollection",
        "title": "Add Images to Collection",
        "category": "TIFF Visualizer"
      },
      {
        "command": "tiffVisualizer.openComparisonPanel",
        "title": "Open Image Comparison Panel",
        "category": "TIFF Visualizer"
      },
      {
        "command": "tiffVisualizer.resetAllSettings",
        "title": "Reset All Settings to Defaults",
        "category": "TIFF Visualizer"
      },
      {
        "command": "tiffVisualizer.toggleHistogram",
        "title": "Toggle Histogram",
        "category": "TIFF Visualizer"
      },
      {
        "command": "tiffVisualizer.toggleMetadata",
        "title": "Toggle Metadata Panel",
        "category": "TIFF Visualizer"
      },
      {
        "command": "tiffVisualizer.convertColormapToFloat",
        "title": "Decode Colormap Image to Float",
        "category": "TIFF Visualizer"
      },
      {
        "command": "tiffVisualizer.applyColormap",
        "title": "Apply Colormap (Pseudocolor)",
        "category": "TIFF Visualizer"
      },
      {
        "command": "tiffVisualizer.revertToOriginal",
        "title": "Revert to Original Image",
        "category": "TIFF Visualizer"
      },
      {
        "command": "tiffVisualizer.toggleColorPickerMode",
        "title": "Toggle Color Picker: Show Modified Values",
        "category": "TIFF Visualizer"
      },
      {
        "command": "tiffVisualizer.copyImageInfo",
        "title": "Copy Image Information to Clipboard",
        "category": "TIFF Visualizer"
      },
      {
        "command": "tiffVisualizer.toggleRgb24Mode",
        "title": "Toggle RGB as 24-bit Grayscale",
        "category": "TIFF Visualizer"
      },
      {
        "command": "tiffVisualizer.openAsPointCloud",
        "title": "Open as Point Cloud",
        "category": "TIFF Visualizer"
      }
    ],
    "keybindings": [
      {
        "command": "tiffVisualizer.toggleHistogram",
        "key": "ctrl+h",
        "mac": "cmd+h",
        "when": "activeCustomEditorId =~ /^tiffVisualizer\\.previewEditor(?:\\.option)?$/"
      },
      {
        "command": "tiffVisualizer.toggleMetadata",
        "key": "ctrl+m",
        "mac": "cmd+m",
        "when": "activeCustomEditorId =~ /^tiffVisualizer\\.previewEditor(?:\\.option)?$/"
      },
      {
        "command": "tiffVisualizer.copyImageInfo",
        "key": "ctrl+shift+i",
        "mac": "cmd+shift+i",
        "when": "activeCustomEditorId =~ /^tiffVisualizer\\.previewEditor(?:\\.option)?$/"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "tiffVisualizer.browseAndAddToCollection",
          "title": "Add Image to Visualizer Collection",
          "when": "resourceExtname =~ /^\\.(png|jpe?g|tiff?|exr|pfm|npy|npz|pp[mgb]|hdr|tga|webp|avif|bmp|ico|jxl|fits?|fts|dcm|dicom|nc|cdf|ora|kra|psd|psb|xcf|afphoto|af)$/i && tiffVisualizer.activeMode != 'layers'",
          "group": "navigation@1"
        },
        {
          "command": "tiffVisualizer.browseAndAddToCollection",
          "title": "Add Folder Images to Visualizer Collection",
          "when": "explorerResourceIsFolder && tiffVisualizer.activeMode != 'layers'",
          "group": "navigation@1"
        },
        {
          "command": "tiffVisualizer.addLayer",
          "title": "Add Image as Layer",
          "when": "resourceExtname =~ /^\\.(png|jpe?g|tiff?|exr|pfm|npy|npz|pp[mgb]|hdr|tga|webp|avif|bmp|ico|jxl|fits?|fts|dcm|dicom|nc|cdf|ora|kra|psd|psb|xcf|afphoto|af)$/i && tiffVisualizer.hasActivePreview && tiffVisualizer.activeMode == 'layers'",
          "group": "navigation@1"
        }
      ],
      "editor/context": [
        {
          "command": "tiffVisualizer.selectForCompare",
          "when": "activeCustomEditorId =~ /^tiffVisualizer\\.previewEditor(?:\\.option)?$/",
          "group": "comparison@1"
        },
        {
          "command": "tiffVisualizer.compareWithSelected",
          "when": "activeCustomEditorId =~ /^tiffVisualizer\\.previewEditor(?:\\.option)?$/ && tiffVisualizer.hasComparisonImage",
          "group": "comparison@1"
        }
      ]
    },
    "configuration": {
      "title": "TIFF Visualizer",
      "properties": {
        "tiffVisualizer.gpuAcceleration": {
          "type": "boolean",
          "default": true,
          "description": "Use GPU acceleration via WebGL2 for supported image rendering paths. Disable this if a GPU/driver causes incorrect output or slower rendering."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile:quick",
    "clean": "rimraf out",
    "build:wasm": "cd wasm/tiff-decoder && wasm-pack build --target web --release && cd ../.. && mkdir -p media/wasm && cp wasm/tiff-decoder/pkg/tiff_wasm.js media/wasm/tiff-wasm.js && cp wasm/tiff-decoder/pkg/tiff_wasm_bg.wasm media/wasm/tiff-wasm.wasm && node -e \"const fs=require('fs');const f='media/wasm/tiff-wasm.js';fs.writeFileSync(f,fs.readFileSync(f,'utf8').replace(/tiff_wasm_bg\\.wasm/g,'wasm/tiff-wasm.wasm'))\"",
    "compile": "npm run clean && npm run build:wasm && node ./esbuild.js",
    "compile:quick": "npm run clean && node ./esbuild.js",
    "watch": "npm run clean && node ./esbuild.js --watch",
    "check": "npm run typecheck && npm run test",
    "pretest": "npm run compile:quick && npm run lint",
    "lint": "eslint src media/imagePreview.ts media/decode-worker.ts media/layer-compositor-worker.ts media/comparisonPanel.ts media/modules --ext ts,js",
    "typecheck": "npm run typecheck:src && npm run typecheck:media",
    "typecheck:src": "tsc -p tsconfig.json --noEmit",
    "typecheck:media": "tsc -p media/tsconfig.json --noEmit",
    "test": "npm run test:behavior && npm run test:visualization && npm run test:compositor && npm run test:layers-panel && npm run test:control-behavior && npm run test:wasm && npm run test:ppm && npm run test:formats && npm run test:layered-formats && npm run test:scientific-formats && npm run test:dicom-dataset && npm run test:tiff-sample-formats && npm run test:ome-tiff && npm run test:image-renderer-channels && npm run test:collection-switch",
    "test:unit": "mocha out/test/unit/**/*.test.js",
    "test:integration": "vscode-test",
    "test:behavior": "npm run compile && node test/simple-behavior-test.js",
    "test:scientific-formats": "node test/scientific-formats-test.js",
	"test:dicom-dataset": "node test/dicom-dataset-test.js",
    "test:visualization": "node test/visualization-test.js",
    "test:compositor": "node test/layer-compositor-test.js",
    "test:layers-panel": "node test/layers-panel-tree-test.js",
    "test:control-behavior": "node test/control-behavior-test.js",
    "test:wasm": "node test/wasm-tiff-decode-test.js",
    "test:ppm": "node test/ppm-decode-test.js",
    "test:formats": "node test/format-decode-test.js",
    "test:layered-formats": "node test/layered-preview-test.js",
    "test:tiff-sample-formats": "node test/tiff-sample-format-test.js",
    "test:ome-tiff": "node test/ome-tiff-test.js",
    "test:image-renderer-channels": "node test/image-renderer-channels-test.js",
    "test:collection-switch": "tsc -p tsconfig.json && node test/collection-switch-render-test.js",
    "benchmark:layers": "npm run compile:quick && node test/layer-compositor-benchmark.js",
    "benchmark:layers:4k": "npm run compile:quick && LAYER_BENCH_PRESET=4k node test/layer-compositor-benchmark.js",
    "benchmark:layers:8k": "npm run compile:quick && LAYER_BENCH_PRESET=8k node test/layer-compositor-benchmark.js",
    "test:ui": "npm run compile && extest setup-and-run out/test/ui/**/*.js",
    "test:ui-setup": "extest setup-tests",
    "test:ui-run": "extest run-tests out/test/ui/**/*.js",
    "test:playwright": "playwright test test/playwright/extension-core.spec.ts",
    "build": "webpack"
  },
  "dependencies": {
    "@jsquash/jxl": "^1.3.0",
    "ag-psd": "^31.0.2",
    "fflate": "^0.8.3",
    "geotiff": "^2.1.3",
    "pako": "^2.1.0",
    "parse-exr": "^1.0.2",
    "parse-hdr": "^1.0.0",
    "tga-js": "^1.1.1",
    "tslib": "^2.8.1",
    "upng-js": "^2.1.0",
    "vscode-uri": "^3.0.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^10.0.6",
    "@types/node": "^16.11.7",
    "@types/vscode": "^1.70.0",
    "@typescript-eslint/eslint-plugin": "^7.14.1",
    "@typescript-eslint/parser": "^7.14.1",
    "@vscode/test-cli": "^0.0.9",
    "@vscode/test-electron": "^2.4.0",
    "chai": "^4.3.0",
    "esbuild": "^0.25.5",
    "eslint": "^8.57.0",
    "mocha": "^10.4.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.4.5",
    "vscode-extension-tester": "^8.17.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kleinicke/tiff-visualizer.git"
  }
}
