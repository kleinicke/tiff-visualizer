{
  "name": "image-visualizer",
  "displayName": "Image Visualizer",
  "description": "Analyze images, also works with exr, npy, png, jpg, ppm, pfm and pgm images.",
  "version": "1.6.0",
  "publisher": "sguruswamy",
  "icon": "icon.png",
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "browser": "./out/extension.web.js",
  "categories": [
    "Other"
  ],
  "keywords": [
    "tiff",
    "tif",
    "exr",
    "openexr",
    "ppm",
    "pgm",
    "pbm",
    "image",
    "viewer",
    "visualizer",
    "geotiff",
    "float",
    "scientific",
    "imagery",
    "raster",
    "depth",
    "analysis",
    "pixel",
    "normalization",
    "gamma",
    "brightness",
    "compression",
    "lzw",
    "deflate",
    "uint8",
    "uint16",
    "float16",
    "float32",
    "float64",
    "hdr",
    "hdri",
    "nan",
    "mask",
    "preview",
    "custom editor",
    "netpbm",
    "png",
    "jpg",
    "jpeg",
    "npy"
  ],
  "extensionKind": [
    "ui",
    "workspace"
  ],
  "capabilities": {
    "virtualWorkspaces": true,
    "untrustedWorkspaces": {
      "supported": true
    }
  },
  "contributes": {
    "customEditors": [
      {
        "viewType": "imageVisualizer.previewEditor",
        "displayName": "Image Visualizer",
        "priority": "default",
        "selector": [
          {
            "filenamePattern": "*.{tif,tiff,exr,pfm,npy,npz,ppm,pgm,pbm,png,jpeg,jpg}"
          }
        ]
      }
    ],
    "commands": [
      {
        "command": "imageVisualizer.zoomIn",
        "title": "Zoom In",
        "category": "Image Visualizer"
      },
      {
        "command": "imageVisualizer.zoomOut",
        "title": "Zoom Out",
        "category": "Image Visualizer"
      },
      {
        "command": "imageVisualizer.copyImage",
        "title": "Copy Image",
        "category": "Image Visualizer"
      },
      {
        "command": "imageVisualizer.pastePosition",
        "title": "Paste Position",
        "category": "Image Visualizer"
      },
      {
        "command": "imageVisualizer.resetZoom",
        "title": "Reset Zoom",
        "category": "Image Visualizer"
      },
      {
        "command": "imageVisualizer.setNormalizationRange",
        "title": "Set Normalization Range",
        "category": "Image Visualizer"
      },
      {
        "command": "imageVisualizer.exportAsPng",
        "title": "Export as PNG",
        "category": "Image Visualizer"
      },
      {
        "command": "imageVisualizer.setGamma",
        "title": "Set Gamma",
        "category": "Image Visualizer"
      },
      {
        "command": "imageVisualizer.setBrightness",
        "title": "Set Brightness",
        "category": "Image Visualizer"
      },
      {
        "command": "imageVisualizer.selectForCompare",
        "title": "Select for Compare",
        "category": "Image Visualizer"
      },
      {
        "command": "imageVisualizer.compareWithSelected",
        "title": "Compare with Selected",
        "category": "Image Visualizer"
      },
      {
        "command": "imageVisualizer.filterByMask",
        "title": "Filter by Mask",
        "category": "Image Visualizer"
      },
      {
        "command": "imageVisualizer.toggleNanColor",
        "title": "Toggle NaN Color (Black/Fuchsia)",
        "category": "Image Visualizer"
      },
      {
        "command": "imageVisualizer.openWith",
        "title": "Open with Image Visualizer",
        "category": "Image Visualizer"
      },
      {
        "command": "imageVisualizer.openNextToCurrent",
        "title": "Open Next to Current Image",
        "category": "Image Visualizer"
      },
      {
        "command": "imageVisualizer.openComparisonPanel",
        "title": "Open Image Comparison Panel",
        "category": "Image Visualizer"
      },
      {
        "command": "imageVisualizer.resetAllSettings",
        "title": "Reset All Settings to Defaults",
        "category": "Image Visualizer"
      },
      {
        "command": "imageVisualizer.toggleHistogram",
        "title": "Toggle Histogram",
        "category": "Image Visualizer"
      },
      {
        "command": "imageVisualizer.convertColormapToFloat",
        "title": "Convert Colormap Image to Float",
        "category": "Image Visualizer"
      },
      {
        "command": "imageVisualizer.revertToOriginal",
        "title": "Revert to Original Image",
        "category": "Image Visualizer"
      },
      {
        "command": "imageVisualizer.toggleColorPickerMode",
        "title": "Toggle Color Picker: Show Modified Values",
        "category": "Image Visualizer"
      },
      {
        "command": "imageVisualizer.copyImageInfo",
        "title": "Copy Image Information to Clipboard",
        "category": "Image Visualizer"
      }
    ],
    "keybindings": [
      {
        "command": "imageVisualizer.toggleHistogram",
        "key": "ctrl+h",
        "mac": "cmd+h",
        "when": "activeCustomEditorId == 'imageVisualizer.previewEditor'"
      },
      {
        "command": "imageVisualizer.copyImageInfo",
        "key": "ctrl+shift+i",
        "mac": "cmd+shift+i",
        "when": "activeCustomEditorId == 'imageVisualizer.previewEditor'"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "imageVisualizer.openWith",
          "when": "resourceExtname == .png || resourceExtname == .jpg || resourceExtname == .jpeg || resourceExtname == .tif || resourceExtname == .tiff || resourceExtname == .exr || resourceExtname == .pfm || resourceExtname == .npy || resourceExtname == .npz || resourceExtname == .ppm || resourceExtname == .pgm || resourceExtname == .pbm",
          "group": "navigation@0"
        },
        {
          "command": "imageVisualizer.openNextToCurrent",
          "when": "(resourceExtname == .png || resourceExtname == .jpg || resourceExtname == .jpeg || resourceExtname == .tif || resourceExtname == .tiff || resourceExtname == .exr || resourceExtname == .pfm || resourceExtname == .npy || resourceExtname == .npz || resourceExtname == .ppm || resourceExtname == .pgm || resourceExtname == .pbm) && imageVisualizer.hasActivePreview",
          "group": "navigation@1"
        }
      ],
      "editor/context": [
        {
          "command": "imageVisualizer.selectForCompare",
          "when": "activeCustomEditorId == 'imageVisualizer.previewEditor'",
          "group": "comparison@1"
        },
        {
          "command": "imageVisualizer.compareWithSelected",
          "when": "activeCustomEditorId == 'imageVisualizer.previewEditor' && imageVisualizer.hasComparisonImage",
          "group": "comparison@1"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "clean": "rimraf out",
    "build:wasm": "cd wasm/tiff-decoder && wasm-pack build --target web --release && cd ../.. && mkdir -p media/wasm && cp wasm/tiff-decoder/pkg/tiff_wasm.js media/wasm/tiff-wasm.js && cp wasm/tiff-decoder/pkg/tiff_wasm_bg.wasm media/wasm/tiff-wasm.wasm && sed -i 's/tiff_wasm_bg\\.wasm/wasm\\/tiff-wasm.wasm/g' media/wasm/tiff-wasm.js",
    "compile": "npm run clean && npm run build:wasm && node ./esbuild.js",
    "compile:quick": "npm run clean && node ./esbuild.js",
    "watch": "npm run clean && node ./esbuild.js --watch",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "npm run test:behavior && npm run test:visualization",
    "test:unit": "mocha out/test/unit/**/*.test.js",
    "test:integration": "vscode-test",
    "test:behavior": "npm run compile && node test/simple-behavior-test.js",
    "test:visualization": "node test/visualization-test.js",
    "test:ui": "npm run compile && extest setup-and-run out/test/ui/**/*.js",
    "test:ui-setup": "extest setup-tests",
    "test:ui-run": "extest run-tests out/test/ui/**/*.js",
    "build": "webpack"
  },
  "dependencies": {
    "geotiff": "^2.1.3",
    "pako": "^2.1.0",
    "parse-exr": "^1.0.2",
    "tslib": "^2.8.1",
    "upng-js": "^2.1.0",
    "vscode-uri": "^3.0.6"
  },
  "devDependencies": {
    "@types/chai": "^4.3.0",
    "@types/mocha": "^10.0.6",
    "@types/node": "^16.11.7",
    "@types/vscode": "^1.70.0",
    "@typescript-eslint/eslint-plugin": "^7.14.1",
    "@typescript-eslint/parser": "^7.14.1",
    "@vscode/test-cli": "^0.0.9",
    "@vscode/test-electron": "^2.4.0",
    "chai": "^4.3.0",
    "esbuild": "^0.25.5",
    "eslint": "^8.57.0",
    "mocha": "^10.4.0",
    "rimraf": "^6.0.1",
    "typescript": "^4.9.4",
    "vscode-extension-tester": "^8.17.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kleinicke/image-visualizer.git"
  }
}
