{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ES2020",
        "lib": ["ES2020", "dom"],
        "moduleResolution": "bundler",
        "paths": {
            "tga-js": ["./types/tga-js.d.ts"],
            "parse-hdr": ["./types/parse-hdr.d.ts"],
            "pako": ["./types/pako.d.ts"],
            "upng-js": ["./types/upng-js.d.ts"]
        },
        "typeRoots": ["./types", "../node_modules/@types"],
        "noImplicitAny": true,
        "strict": false,
        "noEmit": true,
        "skipLibCheck": true
    },
    "include": [
        "./imagePreview.ts",
        "./decode-worker.ts",
        "./layer-compositor-worker.ts",
        "./comparisonPanel.ts",
        "./modules/**/*.ts",
        "./types/**/*.d.ts"
    ],
    "exclude": [
        "../node_modules",
        "./imagePreview.bundle.js",
        "./comparisonPanel.bundle.js",
        "./decodeWorker.bundle.js",
        "./layerCompositorWorker.bundle.js",
        "./geotiff.min.js",
        "./pako.min.js",
        "./parse-exr.js",
        "./upng.min.js",
        "./wasm"
    ]
}
