{
    "compilerOptions": {
        "checkJs": true,
        "target": "ES2020",
        "module": "ES2020",
        "lib": ["ES2020", "dom"],
        "moduleResolution": "node",
        "paths": {
            "tga-js": ["./types/tga-js.d.ts"],
            "parse-hdr": ["./types/parse-hdr.d.ts"],
            "libraw-wasm": ["./types/libraw-wasm.d.ts"]
        },
        "typeRoots": ["./types", "../node_modules/@types"],
        "noImplicitAny": true,
        "strict": false
    },
    "include": ["./**/*.js"],
    "exclude": [
        "../node_modules",
        "./imagePreview.bundle.js",
        "./comparisonPanel.js",
        "./geotiff.min.js",
        "./pako.min.js",
        "./parse-exr.js",
        "./upng.min.js",
        "./wasm"
    ]
}
